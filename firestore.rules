rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function actingUserProfilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function actingUserProfileExists() {
      return signedIn() && exists(actingUserProfilePath());
    }

    function actingUserRole() {
      return get(actingUserProfilePath()).data.role;
    }

    // App normalizes many aliases to "admin"; rules must accept the same values stored in Firestore.
    function isAdmin() {
      return actingUserProfileExists() && actingUserRole() in [
        'admin',
        'Admin',
        'ADMIN',
        'HOD (Admin)',
        'hod (admin)',
        'superadmin',
        'administrator',
      ];
    }

    function hasRole(roles) {
      return actingUserProfileExists() && (
        actingUserRole() in roles ||
        (isAdmin() && roles.hasAny(['admin']))
      );
    }

    function isDepartmentHead() {
      return actingUserProfileExists() && actingUserRole() in [
        'dept_estates', 'dept_it', 'dept_admin', 'dept_audit', 'dept_finance',
        'dept_procurement', 'dept_hr', 'dept_projects', 'dept_pprme',
      ];
    }

    function isActingHeadForAssignedDepartment() {
      return resource.data.workflowStep == 'with_department'
        && actingUserProfileExists()
        && (
          (actingUserRole() == 'dept_estates' && resource.data.assignedDepartment == 'estates') ||
          (actingUserRole() == 'dept_it' && resource.data.assignedDepartment == 'it') ||
          (actingUserRole() == 'dept_admin' && resource.data.assignedDepartment == 'admin') ||
          (actingUserRole() == 'dept_audit' && resource.data.assignedDepartment == 'audit') ||
          (actingUserRole() == 'dept_finance' && resource.data.assignedDepartment == 'finance') ||
          (actingUserRole() == 'dept_procurement' && resource.data.assignedDepartment == 'procurement') ||
          (actingUserRole() == 'dept_hr' && resource.data.assignedDepartment == 'hr') ||
          (actingUserRole() == 'dept_projects' && resource.data.assignedDepartment == 'projects') ||
          (actingUserRole() == 'dept_pprme' && resource.data.assignedDepartment == 'pprme')
        );
    }

    match /{document=**} {
      allow read: if signedIn();
    }

    match /items/{itemId} {
      allow write: if signedIn();
      allow delete: if signedIn();
    }

    match /categories/{catId} {
      allow write: if signedIn();
    }

    match /transactions/{txnId} {
      allow write: if signedIn();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /audit_log/{logId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /letters/{letterId} {
      allow read: if signedIn();
      allow create: if hasRole(['admin', 'records_unit', 'ceo_office', 'ceo']) || isDepartmentHead();
      allow update: if hasRole(['admin', 'records_unit', 'ceo_office', 'ceo'])
        || isActingHeadForAssignedDepartment();
      allow delete: if hasRole(['admin', 'records_unit']);
    }
  }
}
