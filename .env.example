# Copy to ".env.local" and fill in from Firebase Console → Project settings → Your apps → SDK setup and configuration.
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" if Firestore Listen/Write streams fail with ERR_CONNECTION_RESET or HTTP 400
# (common on VPN, strict networks, or long-idle browser tabs).
# VITE_FIRESTORE_FORCE_LONG_POLLING=true
